package com.example.sirensightmobile;

import android.content.Context;
import android.content.Intent;
import android.media.MediaPlayer;
import android.media.RingtoneManager;
import android.net.Uri;
import android.os.Bundle;
import android.os.Handler;
import android.os.Looper;
import android.os.VibrationEffect;
import android.os.Vibrator;
import android.view.View;
import android.widget.Button;
import android.widget.LinearLayout;
import android.widget.Switch;
import android.widget.TextView;
import android.widget.Toast;

import androidx.annotation.NonNull;
import androidx.appcompat.app.AppCompatActivity;

import com.google.firebase.database.*;

public class CitizenActivity extends AppCompatActivity {

    private LinearLayout layoutSafe, layoutDanger;
    private Switch switchDrivingMode;
    private Button btnMovedLeft;
    private TextView txtDangerDriver, txtDangerDest;

    private boolean isEmergencyActive = false;
    private final Handler vibrationHandler = new Handler(Looper.getMainLooper());
    private Vibrator vibrator;
    private MediaPlayer mediaPlayer;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_citizen);

        layoutSafe = findViewById(R.id.layoutSafe);
        layoutDanger = findViewById(R.id.layoutDanger);
        switchDrivingMode = findViewById(R.id.switchDrivingMode);
        btnMovedLeft = findViewById(R.id.btnMovedLeft);
        txtDangerDriver = findViewById(R.id.txtDangerDriver);
        txtDangerDest = findViewById(R.id.txtDangerDest);
        findViewById(R.id.btnBack).setOnClickListener(v -> goBackToMenu());

        vibrator = (Vibrator) getSystemService(Context.VIBRATOR_SERVICE);

        DatabaseReference userRef = FirebaseDatabase.getInstance().getReference("users").child("USER-101");
        // Place Citizen in the middle of the new route
        userRef.child("lat").setValue(13.0128);
        userRef.child("lng").setValue(80.2409);
        userRef.child("hasMoved").setValue(false);

        // ==========================================
        // ✅ LISTEN TO PYTHON ENGINE ALERT
        // ==========================================
        userRef.child("alert_state").addValueEventListener(new ValueEventListener() {
            @Override
            public void onDataChange(@NonNull DataSnapshot snapshot) {
                Boolean isDanger = snapshot.getValue(Boolean.class);

                if (isDanger != null && isDanger && switchDrivingMode.isChecked()) {
                    if (!isEmergencyActive) {
                        isEmergencyActive = true;
                        layoutSafe.setVisibility(View.GONE);
                        layoutDanger.setVisibility(View.VISIBLE);
                        txtDangerDriver.setText("🚑 Ambulance Nearby!");
                        txtDangerDest.setText("⚠️ Please Give Way");
                        startAlarmLoop();
                    }
                } else {
                    makeSafe();
                }
            }

            @Override
            public void onCancelled(@NonNull DatabaseError error) {}
        });

        btnMovedLeft.setOnClickListener(v -> {
            makeSafe();
            Toast.makeText(this, "Alarm Silenced. Thank you!", Toast.LENGTH_LONG).show();
            userRef.child("hasMoved").setValue(true);
            userRef.child("lng").setValue(80.2415);
            userRef.child("alert_state").setValue(false);
        });

        switchDrivingMode.setOnCheckedChangeListener((btn, isChecked) -> {
            if (!isChecked) makeSafe();
        });
    }

    private void makeSafe() {
        if (isEmergencyActive) {
            isEmergencyActive = false;
            layoutDanger.setVisibility(View.GONE);
            layoutSafe.setVisibility(View.VISIBLE);
            stopAlarmLoop();
        }
    }

    private void startAlarmLoop() {
        if (mediaPlayer == null) {
            try {
                Uri soundUri = RingtoneManager.getDefaultUri(RingtoneManager.TYPE_ALARM);
                if (soundUri == null)
                    soundUri = RingtoneManager.getDefaultUri(RingtoneManager.TYPE_NOTIFICATION);

                mediaPlayer = MediaPlayer.create(this, soundUri);
                mediaPlayer.setLooping(true);
                mediaPlayer.start();

            } catch (Exception e) {}
        }
        vibrationHandler.removeCallbacksAndMessages(null);
        vibrationHandler.post(vibrationRunnable);
    }

    private void stopAlarmLoop() {
        vibrationHandler.removeCallbacksAndMessages(null);
        if (vibrator != null) vibrator.cancel();
        if (mediaPlayer != null) {
            if (mediaPlayer.isPlaying()) mediaPlayer.stop();
            mediaPlayer.release();
            mediaPlayer = null;
        }
    }

    private final Runnable vibrationRunnable = new Runnable() {
        @Override
        public void run() {
            if (isEmergencyActive && switchDrivingMode.isChecked()) {
                if (android.os.Build.VERSION.SDK_INT >= android.os.Build.VERSION_CODES.O) {
                    vibrator.vibrate(VibrationEffect.createOneShot(500, VibrationEffect.DEFAULT_AMPLITUDE));
                } else { vibrator.vibrate(500); }
                vibrationHandler.postDelayed(this, 1000);
            }
        }
    };

    @Override
    protected void onDestroy() {
        super.onDestroy();
        stopAlarmLoop();
    }

    private void goBackToMenu() {
        getSharedPreferences("SirenPrefs", MODE_PRIVATE).edit().clear().apply();
        startActivity(new Intent(this, LoginActivity.class));
        finish();
    }

    @Override
    public void onBackPressed() {
        goBackToMenu();
    }
}