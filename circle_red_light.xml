package com.example.sirensightmobile;

import android.content.Intent;
import android.content.SharedPreferences;
import android.os.Bundle;
import android.widget.LinearLayout;
import androidx.appcompat.app.AppCompatActivity;
import com.google.firebase.messaging.FirebaseMessaging;

public class LoginActivity extends AppCompatActivity {

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);

        // AUTO LOGIN CHECK
        SharedPreferences prefs = getSharedPreferences("SirenPrefs", MODE_PRIVATE);
        if (prefs.getBoolean("isLoggedIn", false)) {
            openRoleActivity(prefs.getString("role", "CITIZEN"));
            return;
        }

        setContentView(R.layout.activity_login);

        // Bind the 3 Cards
        LinearLayout btnCitizen = findViewById(R.id.btnRoleCitizen);
        LinearLayout btnPolice = findViewById(R.id.btnRolePolice);
        LinearLayout btnDriver = findViewById(R.id.btnRoleDriver);

        // Click Listeners
        btnCitizen.setOnClickListener(v -> saveAndOpen("CITIZEN"));
        btnPolice.setOnClickListener(v -> saveAndOpen("POLICE"));
        btnDriver.setOnClickListener(v -> saveAndOpen("DRIVER"));
    }

    private void saveAndOpen(String role) {
        // SAVE DATA
        getSharedPreferences("SirenPrefs", MODE_PRIVATE).edit()
                .putBoolean("isLoggedIn", true)
                .putString("role", role)
                .apply();

        // SUBSCRIBE TO FCM TOPICS BASED ON ROLE
        if (role.equals("CITIZEN")) {
            FirebaseMessaging.getInstance().subscribeToTopic("lane_a");
        } else if (role.equals("POLICE")) {
            FirebaseMessaging.getInstance().subscribeToTopic("police");
        }
        // Drivers don't subscribe, they broadcast!

        openRoleActivity(role);
    }

    private void openRoleActivity(String role) {
        Intent intent;
        if (role.equals("POLICE")) {
            intent = new Intent(this, PoliceActivity.class);
        } else if (role.equals("DRIVER")) {
            intent = new Intent(this, DriverActivity.class);
        } else {
            intent = new Intent(this, CitizenActivity.class);
        }
        startActivity(intent);
        finish(); // Closes the login screen so user can't press 'back' to it
    }
}