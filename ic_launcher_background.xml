package com.example.sirensightmobile;

import android.Manifest;
import android.content.pm.PackageManager;
import android.os.Build;
import android.os.Bundle;
import android.widget.Button;
import android.widget.TextView;
import android.widget.Toast;
import androidx.appcompat.app.AppCompatActivity;
import androidx.core.app.ActivityCompat;
import androidx.core.content.ContextCompat;
import com.google.firebase.messaging.FirebaseMessaging;

public class MainActivity extends AppCompatActivity {

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);

        // 1. Notification Permission Request (Android 13+)
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.TIRAMISU) {
            if (ContextCompat.checkSelfPermission(this, Manifest.permission.POST_NOTIFICATIONS)
                    != PackageManager.PERMISSION_GRANTED) {
                ActivityCompat.requestPermissions(this,
                        new String[]{Manifest.permission.POST_NOTIFICATIONS}, 101);
            }
        }

        Button btnPolice = findViewById(R.id.btnPolice);
        Button btnCitizen = findViewById(R.id.btnCitizen);
        TextView txtStatus = findViewById(R.id.txtStatus);

        // 2. Police Subscription Logic
        btnPolice.setOnClickListener(v -> {
            FirebaseMessaging.getInstance().subscribeToTopic("police")
                    .addOnCompleteListener(task -> {
                        if (task.isSuccessful()) {
                            // Unsubscribe from Citizen to prevent receiving duplicate/wrong alerts
                            FirebaseMessaging.getInstance().unsubscribeFromTopic("lane_a");

                            txtStatus.setText("✅ POLICE MODE ACTIVE");
                            Toast.makeText(this, "Subscribed to Police", Toast.LENGTH_SHORT).show();
                        } else {
                            Toast.makeText(this, "Failed to subscribe. Check network.", Toast.LENGTH_SHORT).show();
                        }
                    });
        });

        // 3. Citizen Subscription Logic
        btnCitizen.setOnClickListener(v -> {
            FirebaseMessaging.getInstance().subscribeToTopic("lane_a")
                    .addOnCompleteListener(task -> {
                        if (task.isSuccessful()) {
                            // Unsubscribe from Police to prevent receiving duplicate/wrong alerts
                            FirebaseMessaging.getInstance().unsubscribeFromTopic("police");

                            txtStatus.setText("✅ CITIZEN MODE ACTIVE");
                            Toast.makeText(this, "Subscribed to Citizen", Toast.LENGTH_SHORT).show();
                        } else {
                            Toast.makeText(this, "Failed to subscribe. Check network.", Toast.LENGTH_SHORT).show();
                        }
                    });
        });
    }
}