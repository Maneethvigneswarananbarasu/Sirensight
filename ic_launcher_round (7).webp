<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/layoutSafe"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#0B0F19"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="40dp">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="←"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginRight="16dp"
                android:clickable="true"
                android:focusable="true"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚨 Citizen Module"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COMMUTER ALERT SYSTEM"
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    android:letterSpacing="0.1"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="60dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚗"
                android:textSize="24sp"
                android:layout_marginRight="16dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Driving Mode"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pause all alerts while parked"
                    android:textColor="#94A3B8"
                    android:textSize="14sp"/>
            </LinearLayout>

            <Switch
                android:id="@+id/switchDrivingMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:theme="@style/Widget.AppCompat.CompoundButton.Switch"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:background="@drawable/circle_green"
                android:text="🛡️"
                android:textSize="50sp"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅ WAY CLEAR"
                android:textColor="#22C55E"
                android:textSize="32sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No emergency vehicles detected in your\nvicinity. Drive safely."
                android:textColor="#64748B"
                android:textSize="16sp"
                android:gravity="center"/>
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutDanger"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#DC2626"
        android:padding="24dp"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/circle_red_light"
            android:text="🚨"
            android:textSize="60sp"
            android:gravity="center"
            android:layout_marginBottom="30dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚨 AMBULANCE\nNEARBY"
            android:textColor="#FFFFFF"
            android:textSize="36sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:id="@+id/txtDangerDriver"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Driver: Loading..."
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/txtDangerDest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="En route to: Loading..."
            android:textColor="#FEF2F2"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Please move to the left side of the road\nimmediately"
            android:textColor="#FEF2F2"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginBottom="50dp"/>

        <Button
            android:id="@+id/btnMovedLeft"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="←  I HAVE MOVED LEFT"
            android:textColor="#DC2626"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#FFFFFF"/>

    </LinearLayout>

</FrameLayout>