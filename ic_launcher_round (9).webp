<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0F19">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/card_blue"
                android:text="🚨"
                android:textSize="30sp"
                android:gravity="center"
                android:layout_marginRight="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SirenSight"
                android:textColor="#FFFFFF"
                android:textSize="38sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Real-time emergency vehicle alert system.\nEvery second counts."
            android:textColor="#94A3B8"
            android:textSize="16sp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="40dp"/>

        <LinearLayout
            android:id="@+id/btnRoleCitizen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_green"
            android:orientation="vertical"
            android:padding="24dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📡"
                android:textSize="24sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Citizen"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COMMUTER ALERT SYSTEM"
                android:textColor="#34D399"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Get real-time alerts when an ambulance approaches your area. Stay safe, save lives."
                android:textColor="#94A3B8"
                android:lineSpacingExtra="4dp"
                android:textSize="14sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnRolePolice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_blue"
            android:orientation="vertical"
            android:padding="24dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛡️"
                android:textSize="24sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Police"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TRAFFIC COMMAND CENTER"
                android:textColor="#60A5FA"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage junction traffic, receive targeted alerts, and monitor city-wide ambulance activity."
                android:textColor="#94A3B8"
                android:lineSpacingExtra="4dp"
                android:textSize="14sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnRoleDriver"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_red"
            android:orientation="vertical"
            android:padding="24dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚑"
                android:textSize="24sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ambulance Driver"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EMERGENCY CONSOLE"
                android:textColor="#F87171"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Broadcast your route and location in real-time. Navigate to hospitals with one tap."
                android:textColor="#94A3B8"
                android:lineSpacingExtra="4dp"
                android:textSize="14sp"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.0 - EMERGENCY VEHICLE ALERT NETWORK"
            android:textColor="#475569"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="20dp"/>

    </LinearLayout>
</ScrollView>